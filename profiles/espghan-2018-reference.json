{
  "$schema": "./schema/profile.schema.json",
  "meta": {
    "name": "ESPGHAN 2018 Reference (preterm >1500 g)",
    "version": "0.1.0",
    "locale": "en",
    "lastReviewed": "2026-06-16",
    "reviewedBy": "Sahin Parlak (guideline-derived; not center-validated)",
    "description": "Preterm (>1500 g) NICU reference derived from ESPGHAN/ESPEN/ESPR/CSPEN 2018. Clinical dosing is guideline-traceable; product/pharmacy and osmolarity values are representative. Not for clinical use as-is — see DISCLAIMER.md. Provenance: espghan-2018-reference.sources.md."
  },
  "units": { "energy": "kcal", "electrolyte": "mmol" },
  "patient": { "ageBasis": "dayOfLife", "usesGestationalAge": true },
  "fluid": {
    "schedulePerKg": [
      { "dayFrom": 1, "dayTo": 1, "mlPerKg": 70 },
      { "dayFrom": 2, "dayTo": 2, "mlPerKg": 90 },
      { "dayFrom": 3, "dayTo": 3, "mlPerKg": 110 },
      { "dayFrom": 4, "dayTo": 4, "mlPerKg": 130 },
      { "dayFrom": 5, "dayTo": 5, "mlPerKg": 150 },
      { "dayFrom": 6, "dayTo": null, "mlPerKg": 150 }
    ],
    "phototherapyAdjMlPerKg": 15,
    "radiantWarmerAdjMlPerKg": 15,
    "maxVolumePerKg": 180
  },
  "energy": {
    "targetKcalPerKg": { "min": 90, "max": 120 },
    "kcalPerGram": { "carbohydrate": 3.75, "protein": 4, "fat": 10 }
  },
  "glucose": {
    "girStart": 4,
    "girAdvance": 2,
    "girMax": 12,
    "maxConcPeripheral": 12.5,
    "maxConcCentral": 25,
    "stockConcentrations": [5, 10, 20, 30, 50]
  },
  "aminoAcid": {
    "product": { "name": "Pediatric amino acid 10% (representative)", "concentrationPct": 10 },
    "doseStart": 1.5,
    "doseAdvance": 1.0,
    "doseMax": 3.5
  },
  "lipid": {
    "product": { "name": "Lipid emulsion 20% (representative)", "concentrationPct": 20 },
    "doseStart": 1.0,
    "doseAdvance": 1.0,
    "doseMax": 4.0
  },
  "electrolytes": {
    "sodium": { "dosePerKg": 3, "stockConcentration": 1.0 },
    "potassium": { "dosePerKg": 2, "stockConcentration": 1.0 },
    "calcium": { "dosePerKg": 1.6, "stockConcentration": 0.225 },
    "magnesium": { "dosePerKg": 0.2, "stockConcentration": 0.5 },
    "phosphate": { "dosePerKg": 1.6, "stockConcentration": 1.0 },
    "chloride": { "dosePerKg": 3, "stockConcentration": 1.0 }
  },
  "additives": {
    "traceElements": { "enabled": true, "dosePerKg": 1.0 },
    "vitamins": { "enabled": true, "dosePerKg": 1.0 },
    "heparin": { "enabled": false, "dosePerKg": 0 }
  },
  "osmolarity": {
    "dextroseMOsmPerGram": 5.0,
    "aminoAcidMOsmPerGram": 10,
    "electrolyteMOsmPerUnit": {
      "sodium": 1,
      "potassium": 1,
      "calcium": 1,
      "magnesium": 1,
      "phosphate": 1,
      "chloride": 1
    },
    "peripheralMaxMOsmPerL": 900
  },
  "caPhosphate": { "maxSolubilityProduct": 200 },
  "safety": {
    "defaultLine": "central",
    "rules": [
      { "id": "gir-max", "level": "hard", "ref": "glucose.girMax", "message": "GIR upper limit exceeded." },
      { "id": "dextrose-peripheral-max", "level": "hard", "ref": "glucose.maxConcPeripheral", "message": "Dextrose concentration too high for a peripheral line." },
      { "id": "osmolarity-peripheral", "level": "hard", "ref": "osmolarity.peripheralMaxMOsmPerL", "message": "Osmolarity upper limit exceeded for a peripheral line." },
      { "id": "ca-phosphate-precipitation", "level": "hard", "ref": "caPhosphate.maxSolubilityProduct", "message": "Calcium-phosphate precipitation risk." },
      { "id": "volume-overflow", "level": "soft", "ref": "fluid.maxVolumePerKg", "message": "Total volume exceeds the upper limit." }
    ]
  }
}
