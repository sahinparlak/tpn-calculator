{
  "$schema": "./schema/profile.schema.json",
  "_note": "This is a TEMPLATE. null = clinical value to fill in, 'FILL_ME' = text to fill in. The engine must not be used until every value is entered from your own source. After filling in, delete the '_note' and '_help' keys.",
  "meta": {
    "name": "Erciyes University NICU",
    "version": "0.1.0",
    "locale": "en",
    "lastReviewed": "FILL_ME-YYYY-MM-DD",
    "reviewedBy": "FILL_ME",
    "description": "Neonatal intensive care unit TPN protocol."
  },
  "units": {
    "energy": "kcal",
    "electrolyte": "mmol"
  },
  "patient": {
    "ageBasis": "dayOfLife",
    "usesGestationalAge": true
  },
  "fluid": {
    "_help": "schedulePerKg: ml/kg/day by age. dayTo:null => that day and onward.",
    "schedulePerKg": [
      { "dayFrom": 1, "dayTo": 1, "mlPerKg": null },
      { "dayFrom": 2, "dayTo": 2, "mlPerKg": null },
      { "dayFrom": 3, "dayTo": null, "mlPerKg": null }
    ],
    "phototherapyAdjMlPerKg": null,
    "radiantWarmerAdjMlPerKg": null,
    "maxVolumePerKg": null
  },
  "energy": {
    "_help": "targetKcalPerKg: kcal/kg/day range. kcalPerGram: energy density per gram (reference/product-dependent).",
    "targetKcalPerKg": { "min": null, "max": null },
    "kcalPerGram": { "carbohydrate": null, "protein": null, "fat": null }
  },
  "glucose": {
    "_help": "GIR in mg/kg/min. maxConc* = max dextrose % by line type.",
    "girStart": null,
    "girAdvance": null,
    "girMax": null,
    "maxConcPeripheral": null,
    "maxConcCentral": null,
    "stockConcentrations": [null]
  },
  "aminoAcid": {
    "product": { "name": "FILL_ME", "concentrationPct": null },
    "doseStart": null,
    "doseAdvance": null,
    "doseMax": null
  },
  "lipid": {
    "product": { "name": "FILL_ME (e.g. SMOFlipid / Intralipid)", "concentrationPct": null },
    "doseStart": null,
    "doseAdvance": null,
    "doseMax": null
  },
  "electrolytes": {
    "_help": "dosePerKg = units.electrolyte per kg/day. stockConcentration = units/mL.",
    "sodium": { "dosePerKg": null, "stockConcentration": null },
    "potassium": { "dosePerKg": null, "stockConcentration": null },
    "calcium": { "dosePerKg": null, "stockConcentration": null },
    "magnesium": { "dosePerKg": null, "stockConcentration": null },
    "phosphate": { "dosePerKg": null, "stockConcentration": null },
    "chloride": { "dosePerKg": null, "stockConcentration": null }
  },
  "additives": {
    "traceElements": { "enabled": true, "dosePerKg": null },
    "vitamins": { "enabled": true, "dosePerKg": null },
    "heparin": { "enabled": false, "dosePerKg": 0 }
  },
  "osmolarity": {
    "_help": "Linear estimate coefficients. dextrose/aminoAcid: mOsm per gram. electrolyteMOsmPerUnit: mOsm per units.electrolyte per ion. peripheralMaxMOsmPerL: peripheral-line upper limit.",
    "dextroseMOsmPerGram": null,
    "aminoAcidMOsmPerGram": null,
    "electrolyteMOsmPerUnit": {
      "sodium": null,
      "potassium": null,
      "calcium": null,
      "magnesium": null,
      "phosphate": null,
      "chloride": null
    },
    "peripheralMaxMOsmPerL": null
  },
  "caPhosphate": {
    "_help": "maxSolubilityProduct: max tolerated Ca x P product in the final admixture (e.g. (mmol/L)^2). Approximation only — see docs/PROFILE.md.",
    "maxSolubilityProduct": null
  },
  "safety": {
    "defaultLine": "central",
    "rules": [
      { "id": "gir-max", "level": "hard", "ref": "glucose.girMax", "message": "GIR upper limit exceeded." },
      { "id": "dextrose-peripheral-max", "level": "hard", "ref": "glucose.maxConcPeripheral", "message": "Dextrose concentration too high for a peripheral line." },
      { "id": "osmolarity-peripheral", "level": "hard", "ref": "osmolarity.peripheralMaxMOsmPerL", "message": "Osmolarity upper limit exceeded for a peripheral line." },
      { "id": "ca-phosphate-precipitation", "level": "hard", "ref": "caPhosphate.maxSolubilityProduct", "message": "Calcium-phosphate precipitation risk." },
      { "id": "volume-overflow", "level": "soft", "ref": "fluid.maxVolumePerKg", "message": "Total volume exceeds the upper limit." }
    ]
  }
}
