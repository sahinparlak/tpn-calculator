{
  "name": "tpn-calculator",
  "version": "0.0.0",
  "private": true,
  "description": "Configurable parenteral nutrition (TPN) calculator for neonatal and pediatric patients.",
  "license": "MIT",
  "author": "Sahin Parlak",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "biome check .",
    "format": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0"
  }
}
